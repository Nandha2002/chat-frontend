import React from 'react'

// Displays starter prompts before the first message is sent.
export default function PredefinedQuestions({ appName, questions = [], onChoose }) {
  return (
    <section className="starter-panel">
      <div className="starter-copy">
        <h1>Choose a question to get started</h1>
        <p>
          Select one of the prompts below to automatically start a chat with {appName},
          or ask your own question below.
        </p>
      </div>

      <div className="prompt-grid">
        {questions.map((q, i) => (
          <button key={i} className="prompt-card" onClick={() => onChoose(q)}>
            <span>{q}</span>
          </button>
        ))}
      </div>
    </section>
  )
}
